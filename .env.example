# Required -- your API key for the LLM provider
OPENAI_API_KEY=sk-xxx

# API base URL (default: OpenRouter)
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Model to use
MODEL=anthropic/claude-sonnet-4

# Max agent loop iterations per query
MAX_ITERATIONS=30

# SQLite database path (used from s03 onward)
DB_PATH=state.db

# Hermes home directory for memory/skills/config (used from s04 onward)
HERMES_HOME=~/.hermes

# Fallback model for error recovery (used from s06 onward, optional)
FALLBACK_MODEL=
FALLBACK_BASE_URL=
FALLBACK_API_KEY=
